@model IEnumerable<HotelBooking_CA2.Models.Room>

@{
    ViewData["Title"] = "Available Rooms";
}

<h2>Available Rooms</h2>

<form method="get" asp-controller="Room" asp-action="Index" class="mt-3 mb-3">
    <div class="input-group" style="max-width: 400px;">
        <input type="text" class="form-control" name="search" value="@ViewData["Search"]" placeholder="Search by room type or number..." />
        <button type="submit" class="btn btn-outline-primary">Search</button>
    </div>
</form>

@if (Model.Any())
{
    <div class="row">
        @foreach (var room in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100">
                    @if (!string.IsNullOrEmpty(room.ImageUrl))
                    {
                        <img src="@room.ImageUrl" class="card-img-top" alt="Room @room.RoomNumber" style="height: 200px; object-fit: cover;" />
                    }
                    else
                    {
                        <img src="https://placehold.co/400x200?text=Room+@room.RoomNumber" class="card-img-top" alt="Room @room.RoomNumber" style="height: 200px; object-fit: cover;" />
                    }
                    <div class="card-body">
                        <h5 class="card-title">Room @room.RoomNumber</h5>
                        <p class="card-text">
                            <strong>Type:</strong> @room.RoomType<br />
                            <strong>Capacity:</strong> @room.Capacity<br />
                            <strong>Price:</strong> €@room.PricePerNight.ToString("F2") / night
                        </p>
                    </div>
                    <div class="card-footer bg-white border-top-0">
                        <a asp-controller="Booking" asp-action="Create" asp-route-roomId="@room.Id" class="btn btn-sm btn-primary">Book</a>
                        <a asp-controller="Room" asp-action="Details" asp-route-id="@room.Id" class="btn btn-sm btn-outline-secondary">Details</a>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <p class="mt-3">No rooms available at the moment.</p>
}
