@model IEnumerable<HotelBooking_CA2.Models.Booking>

@{
    ViewData["Title"] = "All Bookings";
}

<h2>All Bookings</h2>

@if (Model.Any())
{
    <table class="table table-bordered table-striped mt-3">
        <thead>
            <tr>
                <th>Guest</th>
                <th>Room</th>
                <th>Check-In</th>
                <th>Check-Out</th>
                <th>Total Price</th>
                <th>Status</th>
                <th>Booked At</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var booking in Model)
            {
                <tr>
                    <td>@booking.User.FullName</td>
                    <td>@booking.Room.RoomNumber - @booking.Room.RoomType</td>
                    <td>@booking.CheckIn.ToString("dd/MM/yyyy")</td>
                    <td>@booking.CheckOut.ToString("dd/MM/yyyy")</td>
                    <td>€@booking.TotalPrice.ToString("F2")</td>
                    <td>@booking.Status</td>
                    <td>@booking.BookedAt.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>
                        <a asp-controller="Admin" asp-action="EditBooking" asp-route-id="@booking.Id" class="btn btn-sm btn-warning">Edit</a>
                        <form method="post" asp-controller="Admin" asp-action="DeleteBooking" style="display:inline;">
                            <input type="hidden" name="id" value="@booking.Id" />
                            <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Delete this booking?')">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p class="mt-3">No bookings yet.</p>
}
