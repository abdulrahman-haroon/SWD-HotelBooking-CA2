@model dynamic

@{
    var user = (HotelBooking_CA2.Models.User)Model.User;
    ViewData["Title"] = "Edit User - " + user.FullName;
}

<h2>Edit User</h2>

@if (!string.IsNullOrEmpty(Model.Error))
{
    <div class="alert alert-danger">@Model.Error</div>
}

<form method="post" asp-controller="Admin" asp-action="EditUser" style="max-width: 500px;" class="mt-3">
    <input type="hidden" name="id" value="@user.Id" />

    <div class="mb-3">
        <label for="fullName" class="form-label">Full Name</label>
        <input type="text" class="form-control" id="fullName" name="fullName" value="@user.FullName" required />
    </div>

    <div class="mb-3">
        <label for="email" class="form-label">Email</label>
        <input type="email" class="form-control" id="email" name="email" value="@user.Email" required />
    </div>

    <div class="mb-3">
        <label for="role" class="form-label">Role</label>
        <select class="form-select" id="role" name="role" required>
            @{
                var roles = new[] { "Guest", "Admin" };
                foreach (var r in roles)
                {
                    if (r == user.Role)
                    {
                        <option value="@r" selected>@r</option>
                    }
                    else
                    {
                        <option value="@r">@r</option>
                    }
                }
            }
        </select>
    </div>

    <button type="submit" class="btn btn-warning">Save Changes</button>
    <a asp-controller="Admin" asp-action="Users" class="btn btn-secondary">Cancel</a>
</form>
