@model IEnumerable<HotelBooking_CA2.Models.User>

@{
    ViewData["Title"] = "Manage Users";
}

<h2>Manage Users</h2>

<a asp-controller="Admin" asp-action="CreateUser" class="btn btn-success mt-2 mb-3">Add User</a>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Password</th>
            <th>Role</th>
            <th>Created At</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.FullName</td>
                <td>@user.Email</td>
                <td>@user.Password</td>
                <td>@user.Role</td>
                <td>@user.CreatedAt.ToString("dd/MM/yyyy")</td>
                <td>
                    <a asp-controller="Admin" asp-action="EditUser" asp-route-id="@user.Id" class="btn btn-sm btn-warning">Edit</a>
                    <form method="post" asp-controller="Admin" asp-action="DeleteUser" style="display:inline;">
                        <input type="hidden" name="id" value="@user.Id" />
                        <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Delete this user?')">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
