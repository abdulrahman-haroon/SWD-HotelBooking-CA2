@model dynamic

@{
    ViewData["Title"] = "Admin Dashboard";
}

<h2>Admin Dashboard</h2>

<div class="row mt-3">
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Rooms</h5>
                <p class="card-text">Total: @Model.TotalRooms</p>
                <a asp-controller="Admin" asp-action="Rooms" class="btn btn-primary">Manage Rooms</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Bookings</h5>
                <p class="card-text">Total: @Model.TotalBookings</p>
                <a asp-controller="Admin" asp-action="Bookings" class="btn btn-primary">View Bookings</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Users</h5>
                <p class="card-text">Total: @Model.TotalUsers</p>
                <a asp-controller="Admin" asp-action="Users" class="btn btn-primary">Manage Users</a>
            </div>
        </div>
    </div>
</div>
