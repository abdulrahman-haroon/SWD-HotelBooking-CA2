@model dynamic

@{
    var booking = (HotelBooking_CA2.Models.Booking)Model.Booking;
    ViewData["Title"] = "Edit Booking #" + booking.Id;
}

<h2>Edit Booking #@booking.Id</h2>

<div class="card mt-3" style="max-width: 500px;">
    <div class="card-body">
        <p><strong>Guest:</strong> @booking.User.FullName</p>
        <p><strong>Room:</strong> @booking.Room.RoomNumber - @booking.Room.RoomType</p>
        <p><strong>Booked At:</strong> @booking.BookedAt.ToString("dd/MM/yyyy HH:mm")</p>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.Error))
{
    <div class="alert alert-danger mt-3">@Model.Error</div>
}

<form method="post" asp-controller="Admin" asp-action="EditBooking" style="max-width: 500px;" class="mt-3">
    <input type="hidden" name="id" value="@booking.Id" />

    <div class="mb-3">
        <label for="checkIn" class="form-label">Check-In Date</label>
        <input type="date" class="form-control" id="checkIn" name="checkIn" value="@booking.CheckIn.ToString("yyyy-MM-dd")" required />
    </div>

    <div class="mb-3">
        <label for="checkOut" class="form-label">Check-Out Date</label>
        <input type="date" class="form-control" id="checkOut" name="checkOut" value="@booking.CheckOut.ToString("yyyy-MM-dd")" required />
    </div>

    <div class="mb-3">
        <label for="status" class="form-label">Status</label>
        <select class="form-select" id="status" name="status" required>
            @{
                var statuses = new[] { "Confirmed", "Cancelled", "Completed" };
                foreach (var s in statuses)
                {
                    if (s == booking.Status)
                    {
                        <option value="@s" selected>@s</option>
                    }
                    else
                    {
                        <option value="@s">@s</option>
                    }
                }
            }
        </select>
    </div>

    <button type="submit" class="btn btn-warning">Save Changes</button>
    <a asp-controller="Admin" asp-action="Bookings" class="btn btn-secondary">Cancel</a>
</form>
